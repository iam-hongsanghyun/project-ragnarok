{
  "id": "ragnarok-cost-reporter",
  "name": "Cost Reporter",
  "version": "0.1.0",
  "sdkVersion": "1",
  "entry": "main.py",
  "stage": "post-solve",
  "hook": "analyse",
  "description": "Runs after the optimisation solve. Computes total system cost, levelised cost of energy (LCOE), average nodal price, and a carrier-level cost breakdown.",
  "capabilities": ["analytics-pack"],
  "permissions": ["results.read", "analytics.register"],
  "config": {
    "include_capex": {
      "type": "boolean",
      "label": "Include capital costs",
      "description": "Add annualised capital expenditure (CAPEX) to total_cost and show it as a separate metric.",
      "default": true
    },
    "include_carrier_breakdown": {
      "type": "boolean",
      "label": "Carrier cost breakdown",
      "description": "Compute and show the operating cost split by carrier (fuel type).",
      "default": true
    }
  },
  "ui": {
    "total_cost":            { "label": "Total System Cost",  "unit": "$",     "format": "currency" },
    "total_opex":            { "label": "Operating Cost",     "unit": "$",     "format": "currency" },
    "total_capex":           { "label": "Capital Cost",       "unit": "$",     "format": "currency" },
    "lcoe_per_mwh":          { "label": "LCOE",               "unit": "$/MWh", "format": "number"   },
    "total_energy_mwh":      { "label": "Total Energy Served","unit": "MWh",   "format": "number"   },
    "avg_nodal_price":       { "label": "Avg. Nodal Price",   "unit": "$/MWh", "format": "number"   },
    "max_nodal_price":       { "label": "Peak Price",         "unit": "$/MWh", "format": "number"   },
    "min_nodal_price":       { "label": "Min. Price",         "unit": "$/MWh", "format": "number"   },
    "carrier_cost_breakdown":{ "label": "Cost by Carrier",    "unit": "$",     "format": "table"    }
  }
}
