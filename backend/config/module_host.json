{
  "sdk_version": "1",
  "managed_root": {
    "label": "Installed local modules",
    "path": "${PROJECT_ROOT}/.ragnarok/modules"
  },
  "capabilities": [
    "data-importer",
    "data-manipulator",
    "analytics-pack",
    "constraint-pack"
  ],
  "permissions": [
    "filesystem.read",
    "filesystem.write",
    "network.access",
    "workbook.read",
    "workbook.write",
    "results.read",
    "ui.panel",
    "ui.action",
    "constraints.register",
    "analytics.register"
  ]
}
